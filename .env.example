PORT=5000
NODE_ENV=production

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGO_URI=
MASTER_MONGO_URI=
SUPER_MONGO_URI=
LANDING_MONGODB_URI=
USER_MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<user-database>?retryWrites=true&w=majority

# Main frontend URL
FRONTEND_URL=https://your-landing-panel.pages.dev

# Comma-separated allowed origins for all deployed panels plus local development
CORS_ORIGIN=https://your-master-admin.pages.dev,https://your-user-panel.pages.dev,https://your-super-admin.pages.dev,https://your-landing-panel.pages.dev,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://127.0.0.1:5176,http://127.0.0.1:5177,http://localhost:3000,http://127.0.0.1:3000

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

JWT_EXPIRE=7d
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=replace_with_a_strong_password
SUPERADMIN_EMAIL=superadmin@erp-system.com

EMAIL_USER=
EMAIL_PASS=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

DEFAULT_TENANT=cgu
